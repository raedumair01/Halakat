EXPO_PUBLIC_API_URL=https://halakat-backend-pi.vercel.app
EXPO_PUBLIC_GROQ_CHAT_API_KEY=your-chat-groq-api-key
EXPO_PUBLIC_GROQ_VOICE_API_KEY=your-voice-groq-api-key
EXPO_PUBLIC_GROQ_MODEL=llama-3.3-70b-versatile
PORT=4000
MONGODB_URI=mongodb://localhost:27017/Halakat
JWT_SECRET=change-this-in-production

# Vercel deployment:
# Set EXPO_PUBLIC_API_URL in the mobile app to your deployed backend URL,
# for example https://your-project.vercel.app
# Add MONGODB_URI and JWT_SECRET in the Vercel project environment settings.
